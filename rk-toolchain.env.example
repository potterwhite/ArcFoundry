# rk-toolkit2 toolchain override (optional)
# ----------------------------------------------------------------------------
# Leave RKNN_TARBALL_PATH empty (or delete this file entirely) to use the
# official airockchip rknn-toolkit2 repo at the pinned SHA (v2.3.2).
#
# Set RKNN_TARBALL_PATH to an ABSOLUTE path of a local .tgz to install
# from that tarball instead. This is how you use partner-only SDK versions
# (e.g. v2.4.0 for RV1126B) that are not published on GitHub.
#
# Usage:
#   cp rk-toolchain.env.example rk-toolchain.env
#   $EDITOR rk-toolchain.env      # fill in RKNN_TARBALL_PATH (and SHA256)
#
# rk-toolchain.env is in .gitignore; it will never be committed.
# ----------------------------------------------------------------------------

RKNN_TARBALL_PATH=""
RKNN_TARBALL_SHA256=""
