# Use a local rknn-toolkit2 .tgz instead of cloning from GitHub.
# Delete this file (or leave RKNN_TARBALL_PATH empty) to use the default GitHub repo.
#
#   cp rk-toolchain.env.example rk-toolchain.env
#   $EDITOR rk-toolchain.env
#
# rk-toolchain.env is gitignored.

RKNN_TARBALL_PATH=""
RKNN_TARBALL_SHA256=""